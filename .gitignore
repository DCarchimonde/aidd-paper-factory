# Raw and processed molecule data should stay local
paper1_leakage_benchmark/data/raw/*
paper1_leakage_benchmark/data/processed/*
paper1_leakage_benchmark/results/models/*
paper2_admet_benchmark/data/raw/*
paper2_admet_benchmark/data/processed/*
paper2_admet_benchmark/results/models/*
paper2_admet_benchmark/results/logs/*
paper2_admet_benchmark/results/predictions/*
paper2_admet_benchmark/results/conformal/conformal_predictions_*.csv
paper2_admet_benchmark/results/applicability/applicability_details_*.csv

# Small reproducibility outputs can be versioned
!paper1_leakage_benchmark/results/tables/*.csv
!paper1_leakage_benchmark/figures/*.png
!paper2_admet_benchmark/data/manifests/*.csv
!paper2_admet_benchmark/results/tables/*.csv
!paper2_admet_benchmark/results/metrics/*.csv
!paper2_admet_benchmark/results/calibration/*.csv
!paper2_admet_benchmark/results/conformal/conformal_summary_*.csv
!paper2_admet_benchmark/results/applicability/applicability_summary_*.csv
!paper2_admet_benchmark/results/selective/*.csv
!paper2_admet_benchmark/figures/*.png

# Keep directory placeholders
!**/.gitkeep

